<div class="space-y-6">
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
    <h1 class="text-3xl font-black text-white">Consulta de <span class="text-indigo-400">Saldo</span></h1>
    <span class="text-xs font-bold text-slate-500 uppercase tracking-widest bg-slate-800/50 px-3 py-1 rounded-full px-3 py-1">Banco Inter (Sandbox)</span>
  </div>

  <div class="container">
    <%= form_with url: balances_path, method: :get, local: true do |form| %>
      <div class="flex flex-col md:flex-row items-end gap-4">
        <div class="flex-1">
          <%= form.label :date, "Data de Referência (Opcional)", class: "block text-xs font-bold text-slate-500 uppercase tracking-wider mb-3" %>
          <%= form.date_field :date, value: @date, class: 'input-field w-full' %>
        </div>
        <div>
          <%= form.submit "Consultar Saldo Agora", class: 'btn-primary w-full md:w-auto' %>
        </div>
      </div>
    <% end %>
  </div>

  <% if @error %>
    <div class="alert error">
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
      <span><%= @error %></span>
    </div>
  <% end %>

  <% if @balance_data %>
    <div class="container">
      <% if @balance_data['error'] || @balance_data['title'] %>
        <div class="py-12 text-center">
          <div class="text-rose-400 font-bold mb-4">Erro na API</div>
          <pre class="bg-black/20 p-4 rounded-xl text-left text-xs overflow-auto text-slate-400 border border-white/5"><%= JSON.pretty_generate(@balance_data) %></pre>
        </div>
      <% else %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="balance-item available p-8">
            <span class="label">Disponível</span>
            <span class="value text-4xl block mt-2 tracking-tighter"><%= number_to_currency(@balance_data['disponivel'], unit: "R$ ", separator: ",", delimiter: ".") %></span>
          </div>
          
          <div class="balance-item p-6">
            <span class="label">Bloqueado (Cheque)</span>
            <span class="value text-2xl block mt-2 text-slate-300"><%= number_to_currency(@balance_data['bloqueadoCheque'], unit: "R$ ", separator: ",", delimiter: ".") %></span>
          </div>

          <div class="balance-item p-6">
            <span class="label">Bloqueado (Judicial)</span>
            <span class="value text-2xl block mt-2 text-slate-300"><%= number_to_currency(@balance_data['bloqueadoJudicialmente'], unit: "R$ ", separator: ",", delimiter: ".") %></span>
          </div>

          <div class="balance-item p-6">
            <span class="label">Bloqueado (Adm)</span>
            <span class="value text-2xl block mt-2 text-slate-300"><%= number_to_currency(@balance_data['bloqueadoAdministrativo'], unit: "R$ ", separator: ",", delimiter: ".") %></span>
          </div>

          <div class="balance-item p-6">
            <span class="label">Limite Total</span>
            <span class="value text-2xl block mt-2 text-indigo-400/80"><%= number_to_currency(@balance_data['limite'], unit: "R$ ", separator: ",", delimiter: ".") %></span>
          </div>
        </div>
        
        <div class="mt-8 flex justify-end">
          <div class="text-[10px] font-bold text-slate-500 uppercase flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
            Sincronizado em: <%= @balance_data['dataReferencia'] %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

