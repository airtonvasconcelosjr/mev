<div class="space-y-6">
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
    <h1 class="text-3xl font-black text-white">Extrato <span class="text-indigo-400">Bancário</span></h1>
  </div>
  
  <div class="container overflow-visible">
    <%= form_with url: statements_path, method: :get, local: true do |form| %>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
        <div>
          <%= form.label :start_date, "Início", class: "block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2" %>
          <%= form.date_field :start_date, value: @start_date, class: 'input-field w-full' %>
        </div>
        <div>
          <%= form.label :end_date, "Fim", class: "block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2" %>
          <%= form.date_field :end_date, value: @end_date, class: 'input-field w-full' %>
        </div>
        <div>
          <%= form.label :search, "Pesquisa", class: "block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2" %>
          <%= form.text_field :search, value: @search_text, class: 'input-field w-full', placeholder: "Pix, Nome..." %>
        </div>
        <div>
          <%= form.label :category, "Categoria", class: "block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2" %>
          <%= form.select :category, options_for_select([['Todas', '']] + @categories.map { |c| [c, c] }, @category_filter), {}, { class: 'input-field w-full' } %>
        </div>
      </div>

      <div class="flex gap-2 mt-6">
        <%= form.submit "Filtrar Resultados", class: 'btn-primary flex-1 md:flex-none' %>
        <%= link_to "Limpar", statements_path, class: 'btn-secondary flex-1 md:flex-none' %>
      </div>
    <% end %>
  </div>

  <% if @error %>
    <div class="alert error">
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
      <span><%= @error %></span>
    </div>
  <% end %>

  <div class="statement-container flex flex-col lg:flex-row gap-8">
    <div class="column lg:w-1/2">
      <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
        <div class="w-2 h-6 bg-emerald-500 rounded-full"></div>
        Entradas <span class="text-xs font-medium text-slate-500 ml-2">(Crédito)</span>
      </h2>
      
      <% if @grouped_transactions[:inflow].empty? %>
        <div class="container py-12 text-center italic text-slate-500">Nenhuma entrada encontrada.</div>
      <% else %>
        <% @grouped_transactions[:inflow].each do |category, data| %>
          <div class="category-card">
            <div class="category-header">
              <span class="category-name"><%= category %></span>
              <span class="category-total positive">+ <%= number_to_currency(data[:total], unit: "R$ ", separator: ",", delimiter: ".") %></span>
            </div>
            <div class="divide-y divide-white/5">
              <% data[:transactions].each do |tx| %>
                <div class="px-4 py-4 flex items-center justify-between group">
                  <div class="flex items-center gap-4">
                    <div class="text-[10px] font-bold text-slate-500 w-8 border-r border-white/10">
                      <%= Date.parse(tx['dataEntrada']).strftime("%d/%m") rescue "??" %>
                    </div>
                    <div>
                      <div class="font-bold text-slate-200 group-hover:text-white transition-colors"><%= tx['display_name'] %></div>
                      <div class="text-[10px] text-slate-500 uppercase font-medium"><%= tx['descricao'] %></div>
                      <span class="category-tag"><%= tx['display_category'] %></span>
                    </div>
                  </div>
                  <div class="text-right">
                    <div class="font-bold text-emerald-400"><%= number_to_currency(tx['valor'], unit: "R$ ", separator: ",", delimiter: ".") %></div>
                    <% if tx['endToEndId'] || tx['idTransacao'] %> 
                       <%= link_to "COMPROVANTE", receipt_path(tx['endToEndId'] || tx['idTransacao']), class: "btn-xs" %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="column lg:w-1/2">
      <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
        <div class="w-2 h-6 bg-rose-500 rounded-full"></div>
        Saídas <span class="text-xs font-medium text-slate-500 ml-2">(Débito)</span>
      </h2>
      
      <% if @grouped_transactions[:outflow].empty? %>
        <div class="container py-12 text-center italic text-slate-500">Nenhuma saída encontrada.</div>
      <% else %>
        <% @grouped_transactions[:outflow].each do |category, data| %>
          <div class="category-card">
            <div class="category-header">
              <span class="category-name"><%= category %></span>
              <span class="category-total negative">- <%= number_to_currency(data[:total], unit: "R$ ", separator: ",", delimiter: ".") %></span>
            </div>
            <div class="divide-y divide-white/5">
              <% data[:transactions].each do |tx| %>
                <div class="px-4 py-4 flex items-center justify-between group">
                  <div class="flex items-center gap-4">
                    <div class="text-[10px] font-bold text-slate-500 w-8 border-r border-white/10">
                      <%= Date.parse(tx['dataEntrada']).strftime("%d/%m") rescue "??" %>
                    </div>
                    <div>
                      <div class="font-bold text-slate-200 group-hover:text-white transition-colors"><%= tx['display_name'] %></div>
                      <div class="text-[10px] text-slate-500 uppercase font-medium"><%= tx['descricao'] %></div>
                      <span class="category-tag"><%= tx['display_category'] %></span>
                    </div>
                  </div>
                  <div class="text-right">
                    <div class="font-bold text-rose-400">- <%= number_to_currency(tx['valor'].to_f.abs, unit: "R$ ", separator: ",", delimiter: ".") %></div>
                    <% if tx['endToEndId'] || tx['idTransacao'] %> 
                       <%= link_to "COMPROVANTE", receipt_path(tx['endToEndId'] || tx['idTransacao']), class: "btn-xs" %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

