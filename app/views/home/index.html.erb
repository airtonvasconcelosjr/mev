<div class="space-y-8">
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
    <div>
      <h1 class="text-3xl font-black tracking-tight text-white mb-1">
        Resumo <span class="text-indigo-400">Mensal</span>
      </h1>
      <p class="text-slate-400 font-medium">
        <%= l(Date.today, format: "%B %Y").capitalize %> • 
        <span class="text-indigo-300/80"><%= Date.parse(@start_date).strftime("%d/%m") %> - <%= Date.parse(@end_date).strftime("%d/%m") %></span>
      </p>
    </div>
  </div>

  <div class="summary-cards">
    <div class="summary-card">
      <div class="label">Saldo Inicial</div>
      <div class="value"><%= number_to_currency(@initial_balance, unit: "R$ ", separator: ",", delimiter: ".") %></div>
      <div class="mt-2 text-[10px] text-slate-500 font-bold uppercase">01/<%= Date.today.strftime("%m/%y") %></div>
    </div>
    
    <div class="summary-card highlight-positive">
      <div class="label">Entradas</div>
      <div class="value">+ <%= number_to_currency(@total_inflow, unit: "R$ ", separator: ",", delimiter: ".") %></div>
      <div class="mt-2 text-[10px] text-emerald-500/50 font-bold uppercase">Este mês</div>
    </div>

    <div class="summary-card highlight-negative">
      <div class="label">Saídas</div>
      <div class="value">- <%= number_to_currency(@total_outflow, unit: "R$ ", separator: ",", delimiter: ".") %></div>
      <div class="mt-2 text-[10px] text-rose-500/50 font-bold uppercase">Este mês</div>
    </div>

    <div class="summary-card">
      <div class="label">Dívidas Manuais</div>
      <div class="value">- <%= number_to_currency(@total_debts, unit: "R$ ", separator: ",", delimiter: ".") %></div>
      <div class="mt-2 text-[10px] text-slate-500 font-bold uppercase">Projetado</div>
    </div>

    <div class="summary-card primary">
      <div class="label">Saldo Atual</div>
      <div class="value"><%= number_to_currency(@current_balance, unit: "R$ ", separator: ",", delimiter: ".") %></div>
      <div class="mt-2 text-[10px] text-indigo-500/50 font-bold uppercase">Hoje</div>
    </div>
  </div>

  <div class="home-grid">
    <div class="container">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold flex items-center gap-2">
          <div class="w-2 h-6 bg-indigo-500 rounded-full"></div>
          Últimas Transações
        </h2>
        <%= link_to statements_path, class: "flex items-center gap-1.5 !mt-0 px-3 py-1.5 bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 hover:bg-indigo-500 hover:text-white rounded-lg transition-all text-xs font-bold uppercase tracking-wider" do %>
          <span>Ver tudo</span>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        <% end %>
      </div>

      <% if @statement_data && @statement_data['transacoes'].present? %>
        <div class="divide-y divide-white/5">
          <% @statement_data['transacoes'].first(5).each do |tx| %>
            <div class="py-4 flex items-center justify-between group transition-all">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-xl <%= tx['tipoOperacao'] == 'C' ? 'bg-emerald-500/10 text-emerald-500' : 'bg-rose-500/10 text-rose-500' %> flex items-center justify-center font-bold text-xs">
                  <%= Date.parse(tx['dataEntrada']).strftime("%d") rescue "??" %>
                </div>
                <div>
                  <div class="font-bold text-slate-200 group-hover:text-white transition-colors"><%= extract_transaction_name(tx) %></div>
                  <div class="text-xs text-slate-500"><%= Date.parse(tx['dataEntrada']).strftime("%b %Y") rescue "" %></div>
                </div>
              </div>
              <div class="text-right">
                <div class="font-black <%= tx['tipoOperacao'] == 'C' ? 'text-emerald-400' : 'text-rose-400' %>">
                  <%= tx['tipoOperacao'] == 'C' ? '+' : '-' %> <%= number_to_currency(tx['valor'].to_f.abs, unit: "R$ ", separator: ",", delimiter: ".") %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="py-12 text-center">
          <div class="text-slate-500 font-medium italic">Sem transações no período.</div>
        </div>
      <% end %>
    </div>

    <div class="container">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold flex items-center gap-2">
          <div class="w-2 h-6 bg-purple-500 rounded-full"></div>
          Próximas Dívidas
        </h2>
        <%= link_to debts_path, class: "flex items-center gap-1.5 !mt-0 px-3 py-1.5 bg-purple-500/10 text-purple-400 border border-purple-500/20 hover:bg-purple-500 hover:text-white rounded-lg transition-all text-xs font-bold uppercase tracking-wider" do %>
          <span>Gerenciar</span>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
        <% end %>
      </div>

      <% if @debts.any? %>
        <div class="divide-y divide-white/5">
          <% @debts.first(5).each do |debt| %>
            <div class="py-4 flex items-center justify-between group">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-xl bg-purple-500/10 text-purple-500 flex items-center justify-center font-bold text-xs">
                  <%= debt.date&.strftime("%d") || "??" %>
                </div>
                <div>
                  <div class="font-bold text-slate-200 group-hover:text-white transition-colors"><%= debt.name %></div>
                  <div class="text-xs text-slate-500"><%= debt.date&.strftime("%b %Y") || "Sem data" %></div>
                </div>
              </div>
              <div class="text-right">
                <div class="font-black text-rose-400">
                  - <%= number_to_currency(debt.value, unit: "R$ ", separator: ",", delimiter: ".") %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="py-12 text-center">
          <div class="text-slate-500 font-medium italic">Nenhuma dívida pendente.</div>
        </div>
      <% end %>
    </div>
  </div>
</div>

