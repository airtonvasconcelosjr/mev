<div class="login-container">
  <div class="login-card">
    <div class="login-header">
      <div class="w-16 h-16 bg-indigo-500 rounded-2xl flex items-center justify-center shadow-2xl mx-auto mb-6 rotate-3 hover:rotate-0 transition-transform duration-300">
        <span class="text-white text-3xl font-black">M</span>
      </div>
      <h1 class="text-white">Banco <span class="text-indigo-400">MEV</span></h1>
      <p>Bem-vindo de volta! Acesse sua conta.</p>
    </div>

    <%= form_with url: login_path, method: :post, local: true do |f| %>
      <div class="space-y-5">
        <div>
          <%= f.label :email, "E-mail", class: "block mb-3 text-sm font-bold text-slate-300 uppercase tracking-wider" %>
          <%= f.email_field :email, placeholder: "exemplo@email.com", required: true, class: "input-field w-full" %>
        </div>

        <div>
          <%= f.label :password, "Senha", class: "block mb-3 text-sm font-bold text-slate-300 uppercase tracking-wider" %>
          <%= f.password_field :password, placeholder: "••••••••", required: true, class: "input-field w-full" %>
        </div>

        <div class="pt-2">
          <%= f.submit "Entrar no Sistema", class: "btn-primary w-full shadow-indigo-500/20 shadow-lg py-4" %>
        </div>
      </div>
    <% end %>

    <div class="mt-8 text-center">
      <p class="text-slate-500 text-xs">© <%= Date.today.year %> Banco MEV. Todos os direitos reservados.</p>
    </div>
  </div>
</div>

